---
import { siteConfig } from "../config";
---

<!-- Accent Shimmer Bar -->
<div
  class="w-full h-2 accent-bar-shimmer"
  style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}
></div>

<section
  id="hero"
  class="relative py-12 md:py-16 lg:py-20 bg-gray-50"
>
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Main Hero Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Photo -->
      <div class="order-2 md:order-1 flex justify-center md:justify-start">
        <div class="relative hero-photo">
          <div
            class="absolute -inset-3 rounded-2xl opacity-20"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="relative w-56 h-56 md:w-72 md:h-72 lg:w-80 lg:h-80 object-cover rounded-2xl shadow-xl"
            style={`border: 4px solid ${siteConfig.highlightColor}`}
          />
        </div>
      </div>

      <!-- Text Content -->
      <div class="order-1 md:order-2 text-center md:text-left">
        <h1
          class="hero-title text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight"
          style={`color: ${siteConfig.accentColor}`}
        >
          {siteConfig.name}
        </h1>
        <p
          class="hero-subtitle text-xl md:text-2xl font-light mt-2 mb-3"
          style={`color: ${siteConfig.highlightColor}`}
        >
          {siteConfig.title}
        </p>
        <div
          class="w-16 h-1 mb-4 mx-auto md:mx-0 rounded-full"
          style={`background-color: ${siteConfig.highlightColor}`}
        ></div>
        <p class="hero-description text-base md:text-lg text-gray-600 leading-relaxed mb-6 max-w-md mx-auto md:mx-0">
          {siteConfig.tagline}
        </p>

        <!-- CTA Button -->
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="hero-cta inline-flex items-center gap-2 px-6 py-3 rounded-full text-white font-medium transition-transform duration-200 hover:scale-105 mb-6"
            style={`background-color: ${siteConfig.highlightColor}`}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Contact Me
          </a>
        )}

        <!-- Social Links -->
        <div class="hero-social flex gap-3 justify-center md:justify-start">
          {siteConfig.social?.email && (
            <a href={`mailto:${siteConfig.social.email}`} class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Email">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </a>
          )}
          {siteConfig.social?.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="X">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M4 4l11.733 16h4.267l-11.733-16z M4 20l6.768-6.768m2.46-2.46l6.772-6.772"/></svg>
            </a>
          )}
          {siteConfig.social?.github && (
            <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          )}
          {siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          )}
          {siteConfig.social?.audible && (
            <a href={siteConfig.social.audible} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Audible">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 4.1C8.2 2.7 10 2 12 2s3.8.7 5.4 2.1l-1.4 1.7C14.8 4.6 13.4 4 12 4s-2.8.6-4 1.8L6.6 4.1zm2.8 3.4C10.2 6.6 11.1 6.1 12 6.1s1.8.4 2.6 1.3l-1.4 1.7c-.4-.4-.8-.6-1.2-.6s-.9.2-1.2.6L9.4 7.5zM12 10c-.8 0-1.5.3-2.1.9l-.7-.7C10 9.4 11 9 12 9s2 .4 2.8 1.2l-.7.7c-.6-.6-1.3-.9-2.1-.9zm0 2c-1.1 0-2 .9-2 2v6c0 1.1.9 2 2 2s2-.9 2-2v-6c0-1.1-.9-2-2-2z"/></svg>
            </a>
          )}
          {siteConfig.social?.soundcloud && (
            <a href={siteConfig.social.soundcloud} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="SoundCloud">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M1.175 12.225c-.051 0-.094.046-.101.1l-.233 2.154.233 2.105c.007.058.05.098.101.098.05 0 .09-.04.099-.098l.255-2.105-.27-2.154c-.009-.057-.049-.1-.084-.1zm-.899 1.396c-.068 0-.116.074-.116.074l-.201 1.058.201 1.042s.043.064.116.064c.058 0 .104-.064.104-.064l.229-1.042-.229-1.058s-.029-.074-.104-.074zm1.819-1.418c-.065 0-.118.057-.118.057l-.213 2.571.213 2.399c0 .066.053.119.118.119.065 0 .118-.053.125-.119l.241-2.399-.241-2.571c-.007-.057-.06-.057-.125-.057zm.899-.392c-.078 0-.14.063-.148.14l-.195 2.963.195 2.839c.008.078.07.14.148.14.078 0 .14-.062.148-.14l.226-2.839-.226-2.963c-.008-.078-.07-.14-.148-.14zm.928-.186c-.091 0-.164.073-.164.164l-.187 3.149.187 2.948c0 .091.073.164.164.164.091 0 .164-.073.172-.164l.209-2.948-.209-3.149c-.008-.091-.081-.164-.172-.164zm.965-.216c-.104 0-.188.084-.188.188l-.176 3.365.176 2.998c0 .104.084.188.188.188.104 0 .188-.084.196-.188l.2-2.998-.2-3.365c-.008-.104-.092-.188-.196-.188zm.972-.17c-.117 0-.211.094-.211.211l-.168 3.535.168 3.033c0 .117.094.211.211.211.117 0 .211-.094.219-.211l.187-3.033-.187-3.535c-.008-.117-.102-.211-.219-.211zm1.005-.139c-.13 0-.234.105-.234.234l-.159 3.674.159 3.059c0 .13.104.234.234.234.13 0 .234-.104.242-.234l.176-3.059-.176-3.674c-.008-.13-.112-.234-.242-.234zm1.012-.109c-.143 0-.258.115-.258.258l-.151 3.783.151 3.075c0 .143.115.258.258.258.143 0 .258-.115.266-.258l.168-3.075-.168-3.783c-.008-.143-.123-.258-.266-.258zm1.003-.064c-.156 0-.281.125-.281.281l-.143 3.847.143 3.086c0 .156.125.281.281.281.156 0 .281-.125.289-.281l.152-3.086-.152-3.847c-.008-.156-.133-.281-.289-.281zm2.025-.088c-.039-.281-.234-.468-.515-.468-.156 0-.297.078-.391.203-.078-.156-.234-.265-.422-.265-.172 0-.32.101-.398.258l-.125 3.891.125 3.078c.008.176.148.32.328.32s.32-.144.328-.32l.105-3.078-.049-1.894c.039-.098.125-.164.234-.164.156 0 .281.125.289.281v-.008l.096 1.785-.096 3.078c.008.078.039.148.094.203.054.055.125.086.203.086.168 0 .305-.133.313-.305l.002-.006.093-3.056-.093-3.871c0-.008-.002-.015-.002-.024-.001-.007-.001-.016-.001-.024zm.982-.057c-.195 0-.351.156-.359.352l-.078 3.967.078 3.023c.008.195.164.352.359.352.195 0 .352-.156.359-.352l.09-3.023-.09-3.967c-.007-.195-.164-.352-.359-.352zm4.026.789c-.234-.789-.891-1.358-1.688-1.442-.203-.023-.406-.023-.586.016-.125.031-.195.109-.211.234l-.055 4.148.055 2.922c.016.172.156.305.328.305.039 0 .078-.008.109-.023.203-.055.344-.234.336-.453v.008l.086-2.891-.055-3.109c.039-.023.086-.047.133-.055.117-.023.242-.031.359-.016.656.07 1.148.617 1.188 1.28v1.922c0 .766.621 1.387 1.387 1.387.766 0 1.387-.621 1.387-1.387v-1.43c0-1.609-1.006-2.985-2.373-3.416z"/></svg>
            </a>
          )}
          {siteConfig.social?.tiktok && (
            <a href={siteConfig.social.tiktok} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="TikTok">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.28 8.28 0 005.58 2.17v-3.45a4.85 4.85 0 01-3.77-1.26V6.69h3.77z"/></svg>
            </a>
          )}
          {siteConfig.social?.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Stats Row -->
    {siteConfig.stats && siteConfig.stats.length > 0 && (
      <div class="hero-stats grid grid-cols-3 gap-4 md:gap-8 mt-12 pt-8 border-t" style={`border-color: ${siteConfig.accentColor}20`}>
        {siteConfig.stats.map((stat) => (
          <div class="text-center stat-number">
            <div class="text-2xl md:text-3xl lg:text-4xl font-bold" style={`color: ${siteConfig.highlightColor}`}>
              {stat.value}
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Bottom Accent Bar -->
<div
  class="w-full h-2 accent-bar-shimmer"
  style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}
></div>
