---
import { siteConfig } from "../config";

const tracks = [
  {
    title: "Narration & VO Reel 2025",
    credit: "Music and prod. by Rodrigo Ponce",
    src: "/audio/narration-vo-reel-2025.mp3",
  },
  {
    title: "Someone To Watch Over Me",
    credit: "G. Gershwin — guitar & prod. Benjamin Scheuer, 2013",
    src: "/audio/someone-to-watch-over-me.mp3",
  },
  {
    title: "Justine",
    credit: "Composition & vox Carina Renner, guitar & prod. Benjamin Scheuer, 2013",
    src: "/audio/justine.mp3",
  },
  {
    title: "Leaving California",
    credit: "Composition, prod. & guitar Benjamin Scheuer",
    src: "/audio/leaving-california.mp3",
  },
  {
    title: "I'll Keep It With Mine",
    credit: "Bob Dylan — guitar & prod. Benjamin Scheuer, 2013",
    src: "/audio/ill-keep-it-with-mine.mp3",
  },
];
---

<section id="listen" class="py-12 md:py-16 bg-white">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="mb-10 reveal-left">
      <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>Listen</h2>
      <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
    </div>

    <div class="space-y-4">
      {tracks.map((track, index) => (
        <div class={`reveal stagger-${index + 1} p-4 rounded-xl bg-gray-50`} style={`border: 1px solid ${siteConfig.accentColor}12`}>
          <div class="flex flex-col sm:flex-row sm:items-center gap-3">
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold" style={`color: ${siteConfig.accentColor}`}>{track.title}</h3>
              <p class="text-xs text-gray-500 mt-0.5">{track.credit}</p>
            </div>
            <audio controls preload="none" class="w-full sm:w-64 h-10 flex-shrink-0">
              <source src={track.src} type="audio/mpeg" />
            </audio>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-6 text-center reveal">
      <a
        href={siteConfig.social.soundcloud}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-300 hover:opacity-80"
        style={`color: ${siteConfig.highlightColor}`}
      >
        More on SoundCloud
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
