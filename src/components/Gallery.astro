---
import { siteConfig } from "../config";
---

<section class="py-12 md:py-16 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="mb-10 reveal-left">
      <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>Gallery</h2>
      <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      <div class="reveal stagger-1 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-1.jpg" alt="Carina performing outdoors" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">Performance & Play</p>
        </div>
      </div>

      <div class="reveal stagger-2 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-2.jpg" alt="Carina at sunset in Arequipa" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">Life Between Worlds</p>
        </div>
      </div>

      <div class="reveal stagger-3 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-collab.jpg" alt="Carina with collaborator Rodrigo Ponce" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">With Rodrigo Ponce, 2025</p>
        </div>
      </div>

      <div class="reveal stagger-4 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-yoga.jpg" alt="Family Yoga Workshop" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">Family Yoga Workshop</p>
        </div>
      </div>

      <div class="reveal stagger-5 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-canto-agua.jpg" alt="Canto Al Agua, Arequipa 2025" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">Canto Al Agua, Arequipa 2025</p>
        </div>
      </div>

      <div class="reveal stagger-5 group relative overflow-hidden rounded-xl shadow-lg">
        <img src="/gallery-rodrigo.jpg" alt="They Can't Take That Away From Me with Rodrigo Ponce" class="w-full h-72 object-cover transition-transform duration-500 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
          <p class="text-white text-sm font-medium p-4">With Rodrigo Ponce, 2024</p>
        </div>
      </div>
    </div>
  </div>
</section>
